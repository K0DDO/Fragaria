<Project>
  <!-- WinUI unpackaged publish omits .pri/.xbf unless copied explicitly -->
  <Target Name="CopyWinUiResourcesToPublish" AfterTargets="Publish">
    <PropertyGroup>
      <_PublishOut Condition="'$(PublishDir)' != ''">$([MSBuild]::EnsureTrailingSlash('$(PublishDir)'))</_PublishOut>
      <_PublishOut Condition="'$(_PublishOut)' == ''">$([MSBuild]::EnsureTrailingSlash('$(OutputPath)'))</_PublishOut>
    </PropertyGroup>

    <Copy
      SourceFiles="$(OutputPath)$(AssemblyName).pri"
      DestinationFolder="$(_PublishOut)"
      SkipUnchangedFiles="true"
      Condition="Exists('$(OutputPath)$(AssemblyName).pri')" />

    <!-- EnableMsixTooling emits resources.pri; unpackaged MRT expects {AssemblyName}.pri -->
    <Copy
      SourceFiles="$(OutputPath)resources.pri"
      DestinationFiles="$(_PublishOut)$(AssemblyName).pri"
      SkipUnchangedFiles="true"
      Condition="!Exists('$(OutputPath)$(AssemblyName).pri') and Exists('$(OutputPath)resources.pri')" />

    <ItemGroup>
      <_PublishXbf Include="$(OutputPath)**\*.xbf" />
      <_PublishXaml Include="$(OutputPath)**\*.xaml" />
    </ItemGroup>

    <Copy
      SourceFiles="@(_PublishXbf)"
      DestinationFiles="@(_PublishXbf->'$(_PublishOut)%(RecursiveDir)%(Filename)%(Extension)')"
      SkipUnchangedFiles="true"
      Condition="'@(_PublishXbf)' != ''" />

    <Copy
      SourceFiles="@(_PublishXaml)"
      DestinationFiles="@(_PublishXaml->'$(_PublishOut)%(RecursiveDir)%(Filename)%(Extension)')"
      SkipUnchangedFiles="true"
      Condition="'@(_PublishXaml)' != ''" />
  </Target>
</Project>
