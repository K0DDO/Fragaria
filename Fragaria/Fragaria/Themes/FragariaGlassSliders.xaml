<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:primitives="using:Microsoft.UI.Xaml.Controls.Primitives">

    <!-- Liquid glass brushes (Apple-style frosted gloss) -->
    <AcrylicBrush x:Key="FragariaLiquidGlassBrush"
                  BackgroundSource="Backdrop"
                  TintColor="#FFFFFFFF"
                  TintOpacity="0.08"
                  FallbackColor="#55FFFFFF"/>

    <AcrylicBrush x:Key="FragariaLiquidTrackBrush"
                  BackgroundSource="Backdrop"
                  TintColor="#FF1F1F23"
                  TintOpacity="0.55"
                  FallbackColor="#CC252529"/>

    <LinearGradientBrush x:Key="FragariaLiquidSpecular" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#99FFFFFF" Offset="0"/>
        <GradientStop Color="#22FFFFFF" Offset="0.35"/>
        <GradientStop Color="#00FFFFFF" Offset="0.7"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="FragariaLiquidFillH" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#6634C75A" Offset="0"/>
        <GradientStop Color="#BB34C75A" Offset="0.6"/>
        <GradientStop Color="#EE5AE878" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="FragariaLiquidFillV" StartPoint="0.5,1" EndPoint="0.5,0">
        <GradientStop Color="#6634C75A" Offset="0"/>
        <GradientStop Color="#BB34C75A" Offset="0.55"/>
        <GradientStop Color="#EE5AE878" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="FragariaLiquidTrackRim" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#55FFFFFF" Offset="0"/>
        <GradientStop Color="#18FFFFFF" Offset="0.5"/>
        <GradientStop Color="#08FFFFFF" Offset="1"/>
    </LinearGradientBrush>

    <!-- Horizontal thumb — glossy pill -->
    <Style x:Key="FragariaLiquidThumbH" TargetType="Thumb">
        <Setter Property="Height" Value="20"/>
        <Setter Property="Width" Value="20"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Grid Width="24" Height="24">
                        <Ellipse Width="22" Height="22" Fill="#3334C75A" Opacity="0.7"/>
                        <Border Width="20" Height="20" CornerRadius="10"
                                BorderBrush="#AAFFFFFF" BorderThickness="1"
                                Background="{StaticResource FragariaLiquidGlassBrush}">
                            <Grid>
                                <Border CornerRadius="10" Background="{StaticResource FragariaLiquidSpecular}" Margin="1,1,1,9"/>
                                <Ellipse Width="6" Height="4" VerticalAlignment="Top" Margin="0,4,0,0"
                                         Fill="#CCFFFFFF" Opacity="0.85"/>
                            </Grid>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Vertical fader thumb — wide glass capsule -->
    <Style x:Key="FragariaLiquidThumbV" TargetType="Thumb">
        <Setter Property="Width" Value="26"/>
        <Setter Property="Height" Value="14"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Grid Width="30" Height="18">
                        <Border Width="28" Height="16" CornerRadius="8" Opacity="0.5"
                                Background="#4434C75A" VerticalAlignment="Center"/>
                        <Border Width="26" Height="14" CornerRadius="7"
                                BorderBrush="#BBFFFFFF" BorderThickness="1"
                                Background="{StaticResource FragariaLiquidGlassBrush}"
                                VerticalAlignment="Center">
                            <Grid>
                                <Border CornerRadius="7" Background="{StaticResource FragariaLiquidSpecular}" Margin="2,1,2,6"/>
                                <Rectangle Width="14" Height="3" RadiusX="1.5" RadiusY="1.5"
                                           VerticalAlignment="Top" Margin="0,3,0,0"
                                           Fill="#DDFFFFFF" Opacity="0.9"/>
                            </Grid>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Horizontal liquid glass slider -->
    <ControlTemplate x:Key="FragariaLiquidSliderTemplateH" TargetType="Slider">
        <Grid x:Name="LayoutRoot" Background="Transparent">
            <Grid x:Name="HorizontalTemplate" Visibility="Visible">
                <Grid x:Name="HorizontalTrack" Height="10" Margin="10,0" VerticalAlignment="Center">
                    <Border Height="10" CornerRadius="5"
                            Background="{StaticResource FragariaLiquidTrackBrush}"
                            BorderBrush="{StaticResource FragariaLiquidTrackRim}"
                            BorderThickness="1"/>
                    <Border Height="4" CornerRadius="2" VerticalAlignment="Top" Margin="3,1,3,0"
                            Background="#18FFFFFF" IsHitTestVisible="False"/>
                    <Rectangle x:Name="HorizontalFill" Height="8" Margin="1" RadiusX="4" RadiusY="4"
                               HorizontalAlignment="Left" Fill="{StaticResource FragariaLiquidFillH}"
                               IsHitTestVisible="False"/>
                </Grid>
                <Thumb x:Name="HorizontalThumb" Style="{StaticResource FragariaLiquidThumbH}"/>
            </Grid>

            <Grid x:Name="VerticalTemplate" Visibility="Collapsed">
                <Grid x:Name="VerticalTrack" Width="10" Margin="0,10" HorizontalAlignment="Center">
                    <Border Width="10" CornerRadius="5"
                            Background="{StaticResource FragariaLiquidTrackBrush}"
                            BorderBrush="{StaticResource FragariaLiquidTrackRim}"
                            BorderThickness="1"/>
                    <Border Width="4" CornerRadius="2" HorizontalAlignment="Left" Margin="1,3,0,3"
                            Background="#18FFFFFF" IsHitTestVisible="False"/>
                    <Rectangle x:Name="VerticalFill" Width="8" Margin="1" RadiusX="4" RadiusY="4"
                               VerticalAlignment="Bottom" Fill="{StaticResource FragariaLiquidFillV}"
                               IsHitTestVisible="False"/>
                </Grid>
                <Thumb x:Name="VerticalThumb" Style="{StaticResource FragariaLiquidThumbV}"/>
            </Grid>

            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="OrientationStates">
                    <VisualState x:Name="Horizontal"/>
                    <VisualState x:Name="Vertical">
                        <Storyboard>
                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="HorizontalTemplate" Storyboard.TargetProperty="Visibility">
                                <DiscreteObjectKeyFrame KeyTime="0" Value="Collapsed"/>
                            </ObjectAnimationUsingKeyFrames>
                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="VerticalTemplate" Storyboard.TargetProperty="Visibility">
                                <DiscreteObjectKeyFrame KeyTime="0" Value="Visible"/>
                            </ObjectAnimationUsingKeyFrames>
                        </Storyboard>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
        </Grid>
    </ControlTemplate>

    <Style x:Key="FragariaSlider" TargetType="Slider">
        <Setter Property="Foreground" Value="{StaticResource FragariaLeafBrush}"/>
        <Setter Property="Minimum" Value="0"/>
        <Setter Property="Maximum" Value="100"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Template" Value="{StaticResource FragariaLiquidSliderTemplateH}"/>
    </Style>

    <Style x:Key="FragariaVerticalFader" TargetType="Slider" BasedOn="{StaticResource FragariaSlider}">
        <Setter Property="Orientation" Value="Vertical"/>
        <Setter Property="Height" Value="140"/>
        <Setter Property="Width" Value="32"/>
    </Style>

    <Style x:Key="FragariaGlassKnobSlider" TargetType="Slider" BasedOn="{StaticResource FragariaSlider}">
        <Setter Property="Height" Value="28"/>
        <Setter Property="Width" Value="48"/>
    </Style>

</ResourceDictionary>
