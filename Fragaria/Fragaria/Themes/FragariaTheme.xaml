<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Fragaria — strawberry palette -->
    <Color x:Key="FragariaBg">#FF0E080A</Color>
    <Color x:Key="FragariaSurface">#FF1A1016</Color>
    <Color x:Key="FragariaSurfaceLight">#FF261820</Color>
    <Color x:Key="FragariaPrimary">#FFE8475F</Color>
    <Color x:Key="FragariaPrimaryGlow">#66E8475F</Color>
    <Color x:Key="FragariaLeaf">#FF3DDC84</Color>
    <Color x:Key="FragariaStream">#FF6B9FFF</Color>
    <Color x:Key="FragariaText">#FFFFF5F6</Color>
    <Color x:Key="FragariaMuted">#99C4A8AC</Color>

    <SolidColorBrush x:Key="FragariaBgBrush" Color="{StaticResource FragariaBg}"/>
    <SolidColorBrush x:Key="FragariaSurfaceBrush" Color="{StaticResource FragariaSurface}"/>
    <SolidColorBrush x:Key="FragariaSurfaceLightBrush" Color="{StaticResource FragariaSurfaceLight}"/>
    <SolidColorBrush x:Key="FragariaPrimaryBrush" Color="{StaticResource FragariaPrimary}"/>
    <SolidColorBrush x:Key="FragariaLeafBrush" Color="{StaticResource FragariaLeaf}"/>
    <SolidColorBrush x:Key="FragariaStreamBrush" Color="{StaticResource FragariaStream}"/>
    <SolidColorBrush x:Key="FragariaTextBrush" Color="{StaticResource FragariaText}"/>
    <SolidColorBrush x:Key="FragariaMutedBrush" Color="{StaticResource FragariaMuted}"/>

    <LinearGradientBrush x:Key="FragariaHeaderGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF1A1016" Offset="0"/>
        <GradientStop Color="#FF2A1420" Offset="0.5"/>
        <GradientStop Color="#FF1A1016" Offset="1"/>
    </LinearGradientBrush>

    <Style x:Key="FragariaCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource FragariaSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="#33E8475F"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <Style x:Key="FragariaTitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource FragariaTextBrush}"/>
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="FragariaLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource FragariaMutedBrush}"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style x:Key="FragariaSlider" TargetType="Slider">
        <Setter Property="Foreground" Value="{StaticResource FragariaPrimaryBrush}"/>
        <Setter Property="Minimum" Value="0"/>
        <Setter Property="Maximum" Value="100"/>
    </Style>
</ResourceDictionary>
