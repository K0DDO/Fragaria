<Window
    x:Class="Fragaria.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Fragaria.Controls"
    Title="Fragaria">

    <Grid Background="#FF1A1A1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="{StaticResource FragariaHeaderGradient}" Padding="28,18" BorderBrush="#33B8203A" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Spacing="16">
                    <Border Width="44" Height="44" CornerRadius="22"
                            BorderBrush="{StaticResource FragariaPrimaryBrush}" BorderThickness="2"
                            Background="#40B8203A">
                        <FontIcon Glyph="&#xE735;" Foreground="{StaticResource FragariaPrimaryBrush}"
                                  FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Spacing="3">
                        <TextBlock Text="FRAGARIA" Style="{StaticResource FragariaWordmark}"/>
                        <TextBlock Text="Pro Audio for Streamers" Style="{StaticResource FragariaTagline}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText" Style="{StaticResource FragariaStatus}"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="48 kHz · 24-bit" Style="{StaticResource FragariaMono}"
                               VerticalAlignment="Center"/>
                    <ComboBox x:Name="PresetCombo" Width="150" PlaceholderText="Пресет" FontSize="12"/>
                    <Button Content="Загрузить" Style="{StaticResource FragariaGhostBtn}" Click="LoadPreset_Click"/>
                    <Button Content="Сохранить" Style="{StaticResource FragariaGhostBtn}" Click="SavePreset_Click"/>
                    <Button x:Name="RecordBtn" Content="● ЗАПИСЬ" Style="{StaticResource FragariaPrimaryBtn}" Click="Record_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ PAGE HOST ═══ -->
        <Grid Grid.Row="1" Margin="12,8,12,0">

            <!-- ── MIXER ── -->
            <Grid x:Name="MixerPage" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Scene presets bar -->
                <Border Grid.Row="0" Style="{StaticResource FragariaGlassPanel}" Padding="14,12" Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="СЦЕНЫ" Style="{StaticResource FragariaSectionAccent}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Button x:Name="SceneGameBtn" Content="Игра" Style="{StaticResource FragariaGhostBtn}" Click="SceneGame_Click"/>
                        <Button x:Name="SceneTalkBtn" Content="Голос" Style="{StaticResource FragariaGhostBtn}" Click="SceneTalk_Click"/>
                        <Button x:Name="SceneStreamBtn" Content="Эфир" Style="{StaticResource FragariaGhostBtn}" Click="SceneStream_Click"/>
                        <Rectangle Width="1" Height="24" Fill="#40FFFFFF" Margin="8,0"/>
                        <TextBlock x:Name="DuckingLabel" Style="{StaticResource FragariaMono}" Foreground="{StaticResource FragariaLeafBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="ObsStatus" Style="{StaticResource FragariaMono}" Foreground="{StaticResource FragariaStreamBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Mixer rack -->
                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal" Spacing="10">

                        <!-- Input section -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="ВХОДЫ" Style="{StaticResource FragariaSectionAccent}" Margin="6,0,0,0"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ItemsControl x:Name="StripsList">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="8"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="viewmodels:StripViewModel"
                                                      xmlns:viewmodels="using:Fragaria.ViewModels">
                                            <Border Style="{StaticResource FragariaChannelStrip}"
                                                    AllowDrop="True" DragOver="Strip_DragOver" Drop="Strip_Drop">
                                                <StackPanel Spacing="10">
                                                    <!-- Header -->
                                                    <StackPanel Spacing="5" HorizontalAlignment="Center">
                                                        <Border Width="36" Height="36" CornerRadius="18"
                                                                Background="#40B8203A" BorderBrush="#66B8203A" BorderThickness="1"
                                                                HorizontalAlignment="Center">
                                                            <Image Source="{x:Bind Icon}" Width="20" Height="20"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Text="{x:Bind Title}" Style="{StaticResource FragariaStripTitle}"/>
                                                        <TextBlock Text="{x:Bind ProcessName}" Style="{StaticResource FragariaStripSub}"/>
                                                    </StackPanel>

                                                    <controls:MiniWaveform HorizontalAlignment="Center"/>

                                                    <!-- Dynamics -->
                                                    <Grid ColumnSpacing="8" HorizontalAlignment="Center">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <controls:KnobControl Grid.Column="0" Header="COMP"
                                                                              Value="{x:Bind CompLevel, Mode=TwoWay}"/>
                                                        <controls:KnobControl Grid.Column="1" Header="GATE"
                                                                              Value="{x:Bind GateLevel, Mode=TwoWay}"/>
                                                    </Grid>

                                                    <!-- Fader + meter -->
                                                    <Grid ColumnSpacing="8" HorizontalAlignment="Center">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <controls:VerticalFaderControl Grid.Column="0" Header="A2"
                                                                                       Value="{x:Bind HeadphonesPercent, Mode=TwoWay}"/>
                                                        <controls:VerticalLedMeter Grid.Column="1" Level="{x:Bind PeakHp, Mode=OneWay}"/>
                                                    </Grid>

                                                    <!-- Routing -->
                                                    <StackPanel Spacing="5">
                                                        <TextBlock Text="МАРШРУТ" Style="{StaticResource FragariaMicroLabel}"/>
                                                        <Grid ColumnSpacing="5" HorizontalAlignment="Center">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <ToggleButton Grid.Column="0" Content="A1" Style="{StaticResource FragariaRoutingToggle}"
                                                                          IsChecked="{x:Bind RouteA1, Mode=TwoWay}"/>
                                                            <ToggleButton Grid.Column="1" Content="A2" Style="{StaticResource FragariaRoutingToggle}"
                                                                          IsChecked="{x:Bind RouteA2, Mode=TwoWay}"/>
                                                            <ToggleButton Grid.Column="2" Content="B1" Style="{StaticResource FragariaRoutingToggle}" IsEnabled="False" Opacity="0.35"/>
                                                            <ToggleButton Grid.Column="3" Content="B2" Style="{StaticResource FragariaRoutingToggle}" IsEnabled="False" Opacity="0.35"/>
                                                        </Grid>
                                                    </StackPanel>

                                                    <!-- Solo / Mute -->
                                                    <Grid ColumnSpacing="8" HorizontalAlignment="Center">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <ToggleButton Grid.Column="0" Content="SOLO" Style="{StaticResource FragariaStripBtn}"
                                                                      IsChecked="{x:Bind Solo, Mode=TwoWay}"/>
                                                        <ToggleButton Grid.Column="1" Content="MUTE" Style="{StaticResource FragariaMuteBtn}"
                                                                      IsChecked="{x:Bind Muted, Mode=TwoWay}"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Add source -->
                                <Border Style="{StaticResource FragariaAddSourceStrip}">
                                    <StackPanel Spacing="12" VerticalAlignment="Stretch">
                                        <Border Background="#30B8203A" CornerRadius="8" Padding="10,8" HorizontalAlignment="Stretch">
                                            <TextBlock Text="+ Добавить источник" Style="{StaticResource FragariaSectionTitle}" TextAlignment="Center"/>
                                        </Border>
                                        <controls:WindowPickerControl x:Name="WindowPicker"/>
                                        <Button Content="Сканировать окна" Style="{StaticResource FragariaGhostBtn}" Click="Rescan_Click" HorizontalAlignment="Stretch"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <Rectangle Width="1" Fill="#22FFFFFF" Margin="4,20"/>

                        <!-- Master section -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="МАСТЕР" Style="{StaticResource FragariaSectionAccent}" Margin="6,0,0,0"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <!-- A1 Stream -->
                                <Border Style="{StaticResource FragariaMasterStrip}">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <Border Background="#2834C75A" CornerRadius="6" Padding="10,5" HorizontalAlignment="Center">
                                            <TextBlock Text="A1" Style="{StaticResource FragariaBusBadge}" Foreground="{StaticResource FragariaLeafBrush}"/>
                                        </Border>
                                        <TextBlock Text="Стрим" Style="{StaticResource FragariaLabel}" TextAlignment="Center"/>
                                        <Grid ColumnSpacing="6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Slider Grid.Column="0" x:Name="MasterStreamSlider" Style="{StaticResource FragariaVerticalFader}" ValueChanged="Master_Changed"/>
                                            <controls:VerticalLedMeter x:Name="MasterStreamMeter" Grid.Column="1" Level="0"/>
                                        </Grid>
                                        <Slider x:Name="MasterStreamLimitSlider" Header="Лимит" Style="{StaticResource FragariaSlider}" ValueChanged="Master_Changed" Maximum="100"/>
                                        <controls:SpectrumMeter x:Name="MasterStreamSpectrum" Width="88" Height="28"/>
                                    </StackPanel>
                                </Border>
                                <!-- A2 Monitor -->
                                <Border Style="{StaticResource FragariaMasterStrip}">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <Border Background="#2834C75A" CornerRadius="6" Padding="10,5" HorizontalAlignment="Center">
                                            <TextBlock Text="A2" Style="{StaticResource FragariaBusBadge}" Foreground="{StaticResource FragariaLeafBrush}"/>
                                        </Border>
                                        <TextBlock Text="Монитор" Style="{StaticResource FragariaLabel}" TextAlignment="Center"/>
                                        <Grid ColumnSpacing="6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Slider Grid.Column="0" x:Name="MasterHpSlider" Style="{StaticResource FragariaVerticalFader}" ValueChanged="Master_Changed"/>
                                            <controls:VerticalLedMeter x:Name="MasterHpMeter" Grid.Column="1" Level="0"/>
                                        </Grid>
                                        <Slider x:Name="MasterHpLimitSlider" Header="Лимит" Style="{StaticResource FragariaSlider}" ValueChanged="Master_Changed" Maximum="100"/>
                                        <controls:SpectrumMeter x:Name="MasterHpSpectrum" Width="88" Height="28"/>
                                    </StackPanel>
                                </Border>
                                <!-- B1 Record -->
                                <Border Style="{StaticResource FragariaMasterStrip}">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <Border Background="#38B8203A" CornerRadius="6" Padding="10,5" HorizontalAlignment="Center">
                                            <TextBlock Text="B1" Style="{StaticResource FragariaBusBadge}" Foreground="{StaticResource FragariaRoseBrush}"/>
                                        </Border>
                                        <TextBlock Text="Запись" Style="{StaticResource FragariaLabel}" TextAlignment="Center"/>
                                        <Border Width="36" Height="156" CornerRadius="8" HorizontalAlignment="Center"
                                                Background="{StaticResource FragariaLiquidTrackBrush}"
                                                BorderBrush="{StaticResource FragariaLiquidTrackRim}" BorderThickness="1">
                                            <TextBlock x:Name="RecordIndicator" Text="ВЫКЛ" Style="{StaticResource FragariaLabel}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <Button x:Name="RecordBusToggle" Content="Включить запись" Style="{StaticResource FragariaPrimaryBtn}" Click="Record_Click" FontSize="11"/>
                                    </StackPanel>
                                </Border>
                                <!-- B2 Music -->
                                <Border Style="{StaticResource FragariaMasterStrip}">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <Border Background="#38B8203A" CornerRadius="6" Padding="10,5" HorizontalAlignment="Center">
                                            <TextBlock Text="B2" Style="{StaticResource FragariaBusBadge}" Foreground="{StaticResource FragariaRoseBrush}"/>
                                        </Border>
                                        <TextBlock Text="Музыка" Style="{StaticResource FragariaLabel}" TextAlignment="Center"/>
                                        <Slider x:Name="MasterMusicSlider" Style="{StaticResource FragariaVerticalFader}" Value="70" ValueChanged="Master_Changed"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- Routing summary -->
                <Border Grid.Row="2" Style="{StaticResource FragariaGlassPanel}" Padding="14,10" Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="20">
                        <TextBlock Text="МАРШРУТИЗАЦИЯ" Style="{StaticResource FragariaSectionAccent}" VerticalAlignment="Center"/>
                        <TextBlock Text="A1 → Стрим  ·  A2 → Монитор  ·  Микрофон → A1+A2  ·  Приложения → по дорожкам"
                                   Style="{StaticResource FragariaBody}" Foreground="{StaticResource FragariaCaptionBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── ROUTING ── -->
            <Grid x:Name="RoutingPage" Visibility="Collapsed">
                <Border Style="{StaticResource FragariaCard}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="ROUTING MATRIX" Style="{StaticResource FragariaTitle}"/>
                        <TextBlock Text="A1 = Stream Mix · A2 = Monitor Mix · Toggle routing per channel strip on the Mixer page."
                                   Style="{StaticResource FragariaLabel}" TextWrapping="Wrap"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Style="{StaticResource FragariaLabel}"/>
                            <TextBlock Grid.Column="1" Text="A1 STREAM" Style="{StaticResource FragariaLabel}" TextAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="A2 MONITOR" Style="{StaticResource FragariaLabel}" TextAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="B1 REC" Style="{StaticResource FragariaLabel}" TextAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="B2 MUSIC" Style="{StaticResource FragariaLabel}" TextAlignment="Center"/>
                            <TextBlock Grid.Row="1" Text="Microphone" Style="{StaticResource FragariaMono}" VerticalAlignment="Center"/>
                            <FontIcon Grid.Row="1" Grid.Column="1" Glyph="&#xE73E;" Foreground="{StaticResource FragariaLeafBrush}" HorizontalAlignment="Center"/>
                            <FontIcon Grid.Row="1" Grid.Column="2" Glyph="&#xE73E;" Foreground="{StaticResource FragariaLeafBrush}" HorizontalAlignment="Center"/>
                        </Grid>
                        <controls:WindowPickerControl x:Name="RoutingWindowPicker" Visibility="Collapsed"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── EFFECTS ── -->
            <Grid x:Name="EffectsPage" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12">
                        <Border Style="{StaticResource FragariaCard}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="EQUALIZER" Style="{StaticResource FragariaTitle}"/>
                                <controls:SpectrumMeter x:Name="EffectsSpectrum" Width="400" Height="80"/>
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider x:Name="FxEqLow" Minimum="-12" Maximum="12" Value="0" Style="{StaticResource FragariaSlider}"/>
                                    <Slider Grid.Column="1" x:Name="FxEqMid" Minimum="-12" Maximum="12" Value="0" Style="{StaticResource FragariaSlider}"/>
                                    <Slider Grid.Column="2" x:Name="FxEqHigh" Minimum="-12" Maximum="12" Value="0" Style="{StaticResource FragariaSlider}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource FragariaCard}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="COMPRESSOR" Style="{StaticResource FragariaTitle}"/>
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider x:Name="FxCompThreshold" Minimum="-40" Maximum="0" Value="-12" Style="{StaticResource FragariaSlider}"/>
                                    <Slider Grid.Column="1" x:Name="FxCompRatio" Minimum="1" Maximum="20" Value="4" Style="{StaticResource FragariaSlider}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource FragariaCard}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="GLOBAL DSP" Style="{StaticResource FragariaTitle}"/>
                                <ToggleSwitch x:Name="NoiseGateToggle" Header="Noise Gate"/>
                                <ToggleSwitch x:Name="DuckingToggle" Header="Ducking"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ── SETTINGS ── -->
            <Grid x:Name="SettingsPage" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource FragariaGlassPanel}" Padding="8">
                            <StackPanel Spacing="4">
                                <Button Content="General" Style="{StaticResource FragariaNavBtnActive}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                                <Button Content="Audio Devices" Style="{StaticResource FragariaNavBtn}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                                <Button Content="Streaming" Style="{StaticResource FragariaNavBtn}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                                <Button Content="Driver" Style="{StaticResource FragariaNavBtn}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource FragariaCard}">
                            <StackPanel Spacing="14" x:Name="SettingsPanel" Width="480">
                                <TextBlock Text="GENERAL" Style="{StaticResource FragariaTitle}"/>
                                <ToggleSwitch x:Name="AutoStartToggle" Header="Launch at Windows startup"/>
                                <ToggleSwitch x:Name="TrayToggle" Header="Minimize to system tray" IsOn="True"/>
                                <ToggleSwitch x:Name="ObsToggle" Header="OBS WebSocket integration"/>
                                <TextBlock Text="AUDIO DEVICES" Style="{StaticResource FragariaSectionTitle}"/>
                                <ComboBox x:Name="SettingsHpCombo" Header="A2 Monitor" Width="400" DisplayMemberPath="Name"/>
                                <ComboBox x:Name="SettingsStreamCombo" Header="A1 Stream" Width="400" DisplayMemberPath="Name"/>
                                <ComboBox x:Name="SettingsMicCombo" Header="Microphone" Width="400" DisplayMemberPath="Name"/>
                                <Button Content="Apply devices" Style="{StaticResource FragariaGhostBtn}" Click="ApplyDevices_Click"/>
                                <TextBlock Text="ENGINE" Style="{StaticResource FragariaSectionTitle}"/>
                                <ComboBox Header="Sample Rate" SelectedIndex="0" Width="200">
                                    <ComboBoxItem Content="48000 Hz"/>
                                    <ComboBoxItem Content="44100 Hz"/>
                                </ComboBox>
                                <ComboBox Header="Buffer Size" SelectedIndex="1" Width="200">
                                    <ComboBoxItem Content="128 samples"/>
                                    <ComboBoxItem Content="256 samples"/>
                                    <ComboBoxItem Content="512 samples"/>
                                </ComboBox>
                                <TextBlock Text="THEME" Style="{StaticResource FragariaSectionTitle}"/>
                                <ComboBox SelectedIndex="0" Width="200">
                                    <ComboBoxItem Content="Fragaria Glass"/>
                                </ComboBox>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- ═══ FOOTER NAV ═══ -->
        <Border Grid.Row="2" Background="#F0141418" BorderBrush="#40B8203A" BorderThickness="0,1,0,0" Padding="20,10">
            <Grid>
                <StackPanel Orientation="Horizontal" Spacing="2">
                    <Button x:Name="NavMixer" Content="Микшер" Style="{StaticResource FragariaNavBtnActive}" Click="NavMixer_Click"/>
                    <Button x:Name="NavRouting" Content="Маршруты" Style="{StaticResource FragariaNavBtn}" Click="NavRouting_Click"/>
                    <Button x:Name="NavEffects" Content="Эффекты" Style="{StaticResource FragariaNavBtn}" Click="NavEffects_Click"/>
                    <Button x:Name="NavSettings" Content="Настройки" Style="{StaticResource FragariaNavBtn}" Click="NavSettings_Click"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="24" HorizontalAlignment="Right">
                    <TextBlock x:Name="CpuLabel" Text="CPU 0.0%" Style="{StaticResource FragariaMono}"/>
                    <TextBlock Text="48.0 kHz" Style="{StaticResource FragariaMono}"/>
                    <TextBlock x:Name="ClockLabel" Style="{StaticResource FragariaMono}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
